<Window x:Class="CoffeeTea.Views.StoreStatisticsReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Report thống kê cửa hàng"
        Width="960"
        Height="720"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <!-- Cần thêm reference đến WindowsFormsIntegration để sử dụng WindowsFormsHost -->
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Report thống kê cửa hàng"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock x:Name="PeriodTextBlock"
                               Margin="0,4,0,0"
                               Style="{StaticResource CaptionTextStyle}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="In Report"
                            Width="110"
                            Height="38"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="PrintButton_Click"/>
                    <Button Content="Đóng"
                            Width="90"
                            Height="38"
                            Margin="8,0,0,0"
                            Style="{StaticResource BaseButtonStyle}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource Brush.Card}"
                BorderBrush="{DynamicResource Brush.BorderSoft}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Medium}">
            <wfi:WindowsFormsHost x:Name="ReportHost"/> <!-- Đây là nơi hiển thị windows forms -->
        </Border>
    </Grid>
</Window>
