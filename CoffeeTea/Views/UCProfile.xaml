<UserControl x:Class="CoffeeTea.Views.UCProfile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="950">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="5"
                               Text="Thông tin tài khoản"
                               Style="{StaticResource SectionTitleTextStyle}"/>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Ảnh đại diện" Style="{StaticResource LabelTextStyle}"/>
                        <Grid Width="126"
                              Height="126"
                              Margin="0,0,0,12">
                            <Ellipse Fill="{DynamicResource Brush.WindowBackground}"
                                     Stroke="{DynamicResource Brush.BorderSoft}"
                                     StrokeThickness="1"/>
                            <Ellipse Visibility="{Binding AvatarImageVisibility}"
                                     Stroke="{DynamicResource Brush.BorderSoft}"
                                     StrokeThickness="1">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding AvatarPath}"
                                                Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding AvatarInitials}"
                                       Visibility="{Binding AvatarInitialsVisibility}"
                                       Foreground="{DynamicResource Brush.PrimaryDark}"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Button Content="Chọn ảnh"
                                Width="126"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SelectAvatarCommand}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Họ tên" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Số điện thoại" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Email" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="4">
                        <TextBlock Text="Tên đăng nhập" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Username}"
                                 IsReadOnly="True"
                                 IsEnabled="False"
                                 Opacity="0.4"
                                 Background="{DynamicResource Brush.WindowBackground}"
                                 Foreground="{DynamicResource Brush.TextSecondary}"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Vai trò" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding RoleName}"
                                 IsReadOnly="True"
                                 IsEnabled="False"
                                 Opacity="0.4"
                                 Background="{DynamicResource Brush.WindowBackground}"
                                 Foreground="{DynamicResource Brush.TextSecondary}"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Địa chỉ" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 Height="86"
                                 VerticalContentAlignment="Top"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Style="{StaticResource AppTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3"
                                Grid.ColumnSpan="5"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <Button Content="Lưu thông tin"
                                Width="140"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveProfileCommand}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="5" Margin="0,6,0,0">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="{DynamicResource Brush.PrimaryDark}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource Brush.Danger}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="3"
                               Text="Đổi mật khẩu"
                               Style="{StaticResource SectionTitleTextStyle}"/>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Mật khẩu hiện tại" Style="{StaticResource LabelTextStyle}"/>
                        <PasswordBox x:Name="CurrentPasswordBox"
                                     PasswordChanged="CurrentPasswordBox_OnPasswordChanged"
                                     Style="{StaticResource AppPasswordBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Mật khẩu mới" Style="{StaticResource LabelTextStyle}"/>
                        <PasswordBox x:Name="NewPasswordBox"
                                     PasswordChanged="NewPasswordBox_OnPasswordChanged"
                                     Style="{StaticResource AppPasswordBoxStyle}"/>

                        <TextBlock Text="Xác nhận mật khẩu mới" Style="{StaticResource LabelTextStyle}"/>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     PasswordChanged="ConfirmPasswordBox_OnPasswordChanged"
                                     Style="{StaticResource AppPasswordBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Đổi mật khẩu"
                                Width="140"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ChangePasswordCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>

