<UserControl x:Class="CoffeeTea.Views.UCCategoryManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QUẢN LÝ DANH MỤC" Style="{StaticResource TitleTextStyle}" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="11,0,0,15">
            <StackPanel>
                <TextBlock Text="Tìm kiếm tên danh mục" Style="{StaticResource LabelTextStyle}" />
                <TextBox Width="250" Style="{StaticResource AppTextBoxStyle}" 
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Tag="Nhập tên danh mục..."/>
            </StackPanel>
        </StackPanel>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Background="{StaticResource Brush.Sidebar}" Padding="15" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Tên danh mục" Style="{StaticResource LabelTextStyle}"/>
                    <TextBox Width="200" Style="{StaticResource AppTextBoxStyle}" Text="{Binding TenDanhMuc,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Mô tả" Style="{StaticResource LabelTextStyle}"/>
                    <TextBox Width="300" Style="{StaticResource AppTextBoxStyle}" Text="{Binding MoTa,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,8">
                    <Button Content="Thêm" Command="{Binding AddCommand}" Style="{StaticResource SuccessButtonStyle}" Width="80" Margin="0,0,5,0"/>
                    <Button Content="Sửa" Command="{Binding UpdateCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="80" Margin="0,0,5,0"/>
                    <Button Content="Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButtonStyle}" Width="80"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                CornerRadius="{StaticResource Radius.Medium}"
                BorderThickness="1"
                BorderBrush="{DynamicResource Brush.BorderSoft}"
                ClipToBounds="True">
            <DataGrid Style="{StaticResource AppDataGridStyle}" 
                      ItemsSource="{Binding Categories}" 
                      SelectedItem="{Binding SelectedCategory}" 
                      RowHeaderWidth="0"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      VerticalGridLinesBrush="Transparent">
                <DataGrid.Columns>

                    <DataGridTemplateColumn Width="2*">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="Mã danh mục" Margin="15,0,0,0"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MaDanhMuc}" Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Tên danh mục" Binding="{Binding TenDanhMuc}" Width="3*"/>
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding MoTa}" Width="3*"/>
                    <DataGridTextColumn Header="Số món" Binding="{Binding Mons.Count}" Width="1*"/>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
