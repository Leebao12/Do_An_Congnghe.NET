<UserControl x:Class="CoffeeTea.Views.UCStaffManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1086">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="QUẢN LÝ NHÂN VIÊN"
                   Style="{StaticResource TitleTextStyle}"/>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Background="{StaticResource Brush.Sidebar}"
                Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Tổng nhân viên"
                               Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding StaffCountText}"
                               Style="{StaticResource TitleTextStyle}"
                               FontSize="26"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Đang làm"
                               Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding ActiveStaffCountText}"
                               Style="{StaticResource TitleTextStyle}"
                               FontSize="26"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Tạm nghỉ / Nghỉ việc"
                               Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding OnLeaveStaffCountText}"
                               Style="{StaticResource TitleTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Thông tin nhân viên"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Mã nhân viên"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding EmployeeId}"
                                 IsReadOnly="True"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Họ tên"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Giới tính"
                                           Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox ItemsSource="{Binding Genders}"
                                          SelectedItem="{Binding Gender}"
                                          Style="{StaticResource AppComboBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ngày sinh"
                                           Style="{StaticResource LabelTextStyle}"/>
                                <DatePicker SelectedDate="{Binding BirthDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}"
                                            Language="vi-VN"
                                            Style="{StaticResource AppDatePickerStyle}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Số điện thoại"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Email"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Địa chỉ"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tên đăng nhập"
                                           Style="{StaticResource LabelTextStyle}"/>
                                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource AppTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Mật khẩu"
                                           Style="{StaticResource LabelTextStyle}"/>
                                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource AppTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Vai trò"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <ComboBox ItemsSource="{Binding Roles}"
                                  DisplayMemberPath="TenVaiTro"
                                  SelectedItem="{Binding SelectedRole}"
                                  Style="{StaticResource AppComboBoxStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ngày vào làm"
                                           Style="{StaticResource LabelTextStyle}"/>
                                <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}"
                                            Language="vi-VN"
                                            Style="{StaticResource AppDatePickerStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Lương cơ bản"
                                           Style="{StaticResource LabelTextStyle}"/>
                                <TextBox Text="{Binding SalaryText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource AppTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Trạng thái"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <ComboBox ItemsSource="{Binding Statuses}"
                                  SelectedItem="{Binding Status}"
                                  Style="{StaticResource AppComboBoxStyle}"/>

                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Thêm"
                                    Command="{Binding AddCommand}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Width="80"
                                    Margin="0,0,5,5"/>
                            <Button Content="Sửa"
                                    Command="{Binding UpdateCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="80"
                                    Margin="0,0,5,5"/>
                            <Button Content="Xóa"
                                    Command="{Binding DeleteCommand}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Width="80"
                                    Margin="0,0,5,5"/>
                            <Button Content="Làm mới"
                                    Command="{Binding ClearCommand}"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Width="90"
                                    Margin="0,0,5,5"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Tìm kiếm nhân viên"
                                   Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Width="320"
                                 HorizontalAlignment="Left"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Nhập mã, tên, vai trò..."
                                 Style="{StaticResource AppTextBoxStyle}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Staffs}"
                              SelectedItem="{Binding SelectedStaff, Mode=TwoWay}"
                              Style="{StaticResource AppDataGridStyle}"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              HeadersVisibility="Column"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã NV"
                                                Binding="{Binding EmployeeId}"
                                                Width="90"/>
                            <DataGridTextColumn Header="Họ tên"
                                                Binding="{Binding FullName}"
                                                Width="150"/>
                            <DataGridTextColumn Header="Giới tính"
                                                Binding="{Binding Gender}"
                                                Width="90"/>
                            <DataGridTextColumn Header="SĐT"
                                                Binding="{Binding Phone}"
                                                Width="115"/>
                            <DataGridTextColumn Header="Tài khoản"
                                                Binding="{Binding Username}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Vai trò"
                                                Binding="{Binding RoleName}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Lương"
                                                Binding="{Binding BaseSalary, StringFormat={}{0:N0} đ, ConverterCulture=vi-VN}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Trạng thái"
                                                Binding="{Binding Status}"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
