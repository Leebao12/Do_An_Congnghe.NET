<UserControl x:Class="CoffeeTea.Views.UCTableStatus"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoffeeTea.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
	<Grid Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Bộ lọc và Chú thích -->
		<Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="Khu vực:" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
					<ComboBox Style="{StaticResource AppComboBoxStyle}" Width="150" Margin="0"
                              ItemsSource="{Binding Areas}" SelectedItem="{Binding SelectedArea}"/>
					<TextBlock Text="Trạng thái:" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="16,0,10,0"/>
					<ComboBox Style="{StaticResource AppComboBoxStyle}" Width="170" Margin="0"
                              ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatus}"/>
				</StackPanel>

				<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
					<Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource Brush.Success}" Margin="0,0,6,0"/>
					<TextBlock Text="Trống" Style="{StaticResource CaptionTextStyle}" Margin="0,0,16,0" VerticalAlignment="Center"/>

					<Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource Brush.Danger}" Margin="0,0,6,0"/>
					<TextBlock Text="Đang phục vụ" Style="{StaticResource CaptionTextStyle}" Margin="0,0,16,0" VerticalAlignment="Center"/>

                    <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource Brush.PrimaryDark}" Margin="0,0,6,0"/>
					<TextBlock Text="Đã đặt" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center"/>
				</StackPanel>
			</Grid>
		</Border>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<ItemsControl ItemsSource="{Binding TableList}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel Orientation="Horizontal"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="150" Height="120" Margin="8" 
                            Command="{Binding DataContext.TableClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
   
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Trống">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Success}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Đang phục vụ">
                                            <Setter Property="Background" Value="{DynamicResource Brush.DangerSoft}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Đã đặt">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Info}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Bảo trì">
                                            <Setter Property="Background" Value="#E0E4E8"/>
     
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                                <TextBlock FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                  
                                            <Setter Property="Text" Value="☕"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding KhuVuc}" Value="Lầu 1">
                                                    <Setter Property="Text" Value="🛋️"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding KhuVuc}" Value="Sân vườn">
                                                    <Setter Property="Text" Value="🌳"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding TrangThai}" Value="Bảo trì">
                                                    <Setter Property="Text" Value="🛠️"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Text="{Binding TenBan}" Style="{StaticResource SectionTitleTextStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding TrangThai}" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding KhuVuc}" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
