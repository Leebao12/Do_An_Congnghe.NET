<UserControl x:Class="CoffeeTea.Views.UCInventory"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoffeeTea.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1086">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
            Style="{StaticResource HighlightCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="📋 Quản lý tồn kho"
                           Style="{StaticResource TitleTextStyle}"/>
                    <TextBlock Text="Theo dõi số lượng tồn, mức tối thiểu và giá trị hàng tồn sau các phiếu nhập."
                           Style="{StaticResource BodyTextStyle}"
                           Margin="0,8,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                    Style="{StaticResource StatusBadgeBorderStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Giá trị tồn kho"
                               Style="{StaticResource CaptionTextStyle}"/>
                        <TextBlock Text="{Binding TotalInventoryValueText}"
                               Style="{StaticResource BodyTextStyle}"
                               FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Summary -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Tổng mặt hàng"
                           Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding TotalItemsText}"
                           Style="{StaticResource TitleTextStyle}"
                           FontSize="26"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Sắp hết"
                           Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding LowStockCountText}"
                           Style="{StaticResource TitleTextStyle}"
                           FontSize="26"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Hết hàng"
                           Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding OutOfStockCountText}"
                           Style="{StaticResource TitleTextStyle}"
                           FontSize="26"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Inventory table -->
            <Border Grid.Column="0"
                Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Danh sách tồn kho"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                        <TextBlock Text="Dữ liệu tồn sẽ tăng sau khi lưu phiếu ở màn Hóa đơn nhập."
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,4,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                             Text="{Binding InventorySearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"
                             Margin="0"/>

                        <ComboBox Grid.Column="2"
                              ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay}"
                              Style="{StaticResource AppComboBoxStyle}"
                              Margin="0"/>

                        <Button Grid.Column="4"
                            Content="Lọc"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding RefreshInventoryCommand}"
                            Margin="0"/>

                        <Button Grid.Column="5"
                            Content="Bỏ lọc"
                            Style="{StaticResource BaseButtonStyle}"
                            Command="{Binding ClearFilterCommand}"
                            Margin="8,0,0,0"/>
                    </Grid>

                    <DataGrid Grid.Row="4"
                          ItemsSource="{Binding InventoryItems}"
                          SelectedItem="{Binding SelectedInventoryItem, Mode=TwoWay}"
                          Style="{StaticResource AppDataGridStyle}"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          HeadersVisibility="Column">             
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã"
                                            Binding="{Binding DrinkId}"
                                            Width="50"/>
                            <DataGridTextColumn Header="Tên món / vật tư"
                                            Binding="{Binding DrinkName}"
                                            Width="*"/>
                            <DataGridTextColumn Header="Danh mục"
                                            Binding="{Binding CategoryName}"
                                            Width="100"/>
                            <DataGridTextColumn Header="Tồn"
                                            Binding="{Binding Quantity}"
                                            Width="40"/>
                            <DataGridTextColumn Header="ĐVT"
                                            Binding="{Binding Unit}"
                                            Width="40"/>
                            <DataGridTextColumn Header="Tối thiểu"
                                            Binding="{Binding MinimumQuantity}"
                                            Width="60"/>
                            <DataGridTextColumn Header="Giá nhập"
                                            Binding="{Binding LastImportPrice, StringFormat={}{0:N0} đ}"
                                            Width="100"/>
                            <DataGridTextColumn Header="Giá trị"
                                            Binding="{Binding TotalValue, StringFormat={}{0:N0} đ}"
                                            Width="100"/>
                            <DataGridTextColumn Header="Trạng thái"
                                            Binding="{Binding StatusText}"
                                            Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Side panel -->
            <Border Grid.Column="2"
                Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Cập nhật mức tồn"
                           Style="{StaticResource SectionTitleTextStyle}"/>
                        <TextBlock Text="Chọn một mặt hàng trong bảng, nhập số lượng tồn hiện tại và mức tồn tối thiểu rồi bấm cập nhật."
                           Style="{StaticResource CaptionTextStyle}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,14"/>

                        <Border Style="{StaticResource SidebarCardStyle}"
                        Padding="14"
                        Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Mặt hàng đang chọn"
                                   Style="{StaticResource CaptionTextStyle}"/>
                                <TextBlock Text="{Binding SelectedInventoryItem.DrinkName, TargetNullValue='Chưa chọn mặt hàng'}"
                                   Style="{StaticResource BodyTextStyle}"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedInventoryItem.StatusText}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Số lượng tồn"
                            Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding InventoryUpdateText, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Tồn tối thiểu"
                           Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding MinimumQuantityText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource AppTextBoxStyle}"/>

                        <Button Content="Cập nhật"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding UpdateInventoryCommand}"
                        Margin="0,0,0,14"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>

</UserControl>
