                                  </Button> 
                            </StackPanel>
                    </StackPanel>
                </Border>-->
            </StackPanel>
        </Border>
<!--    .........................................................                 -->
        <Border Grid.Column="1"
                Style="{StaticResource CardStyle}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Đăng nhập"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="0,0,0,16"/>

                <TextBlock Text="Tên đăng nhập"
                           Style="{StaticResource LabelTextStyle}"/>
                <TextBox Style="{StaticResource AppTextBoxStyle}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Mật khẩu"
                           Style="{StaticResource LabelTextStyle}"/>
                <PasswordBox x:Name="PasswordInput"
                             Style="{StaticResource AppPasswordBoxStyle}"
                             Margin="0,0,0,12"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource Brush.Danger}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           MinHeight="34"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="40"
                            IsDefault="True"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=PasswordInput}">
                        <TextBlock Text="Đăng nhập"/>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource BaseButtonStyle}"
                            Height="40"
                            IsCancel="True"
                            Command="{Binding ExitCommand}">
                        <TextBlock Text="Thoát"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>

