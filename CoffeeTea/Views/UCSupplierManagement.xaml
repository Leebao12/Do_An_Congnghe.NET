<UserControl x:Class="CoffeeTea.Views.UCSupplierManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoffeeTea.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1086">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
            Style="{StaticResource HighlightCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="🏢 Quản lý nhà cung cấp"
                           Style="{StaticResource TitleTextStyle}"/>
                    <TextBlock Text="Lưu thông tin đối tác nhập hàng, số điện thoại, địa chỉ và trạng thái hợp tác."
                           Style="{StaticResource BodyTextStyle}"
                           Margin="0,8,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                    Style="{StaticResource StatusBadgeBorderStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tổng NCC: "
                               Style="{StaticResource CaptionTextStyle}"
                               FontWeight="Bold"/>
                        <TextBlock Text="{Binding SupplierCountText}"
                               Style="{StaticResource BodyTextStyle}"
                               FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Summary cards -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Đang hợp tác"
                           Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding ActiveSupplierCountText}"
                           Style="{StaticResource TitleTextStyle}"
                           FontSize="26"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Tạm ngưng"
                           Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding PauseSupplierCountText}"
                           Style="{StaticResource TitleTextStyle}"
                           FontSize="26"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Mã NCC mới"
                           Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text="{Binding SupplierId}"
                           Style="{StaticResource TitleTextStyle}"
                           FontSize="26"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Form -->
            <Border Grid.Column="0"
                Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Thông tin nhà cung cấp"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Margin="0,0,0,14"/>

                        <TextBlock Text="Mã nhà cung cấp"
                               Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding SupplierId}"
                             IsReadOnly="True"
                             Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Tên nhà cung cấp"
                               Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding SupplierName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Số điện thoại"
                               Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Email"
                               Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Địa chỉ"
                               Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"/>

                        <TextBlock Text="Ghi chú"
                               Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                             Height="70"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource AppTextBoxStyle}"/>

                        <CheckBox Content="Đang hợp tác"
                              IsChecked="{Binding IsActive}"
                              Style="{StaticResource AppCheckBoxStyle}"
                              Margin="0,0,0,14"/>

                        <WrapPanel>
                            <Button Content="Thêm"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding AddSupplierCommand}"/>
                            <Button Content="Sửa"
                                Style="{StaticResource SuccessButtonStyle}"
                                Command="{Binding UpdateSupplierCommand}"/>
                            <Button Content="Xóa"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding DeleteSupplierCommand}"/>
                            <Button Content="Làm mới"
                                Style="{StaticResource BaseButtonStyle}"
                                Command="{Binding ClearSupplierCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- List -->
            <Border Grid.Column="2"
                Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Danh sách nhà cung cấp"
                                   Style="{StaticResource SectionTitleTextStyle}"/>
                            <TextBlock Text="Chọn một dòng để đưa dữ liệu lên form bên trái."
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                            <Button Content="Tìm"
                                Width="90"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SearchSupplierCommand}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1"
                      Grid.RowSpan="1"/>

                    <DockPanel Grid.Row="2">
                        <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                            <TextBox Width="310"
                                 Text="{Binding SupplierSearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 Margin="0,0,10,0"/>
                            <TextBlock Text="Tìm theo mã, tên hoặc số điện thoại"
                                   Style="{StaticResource CaptionTextStyle}"
                                   VerticalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                              Style="{StaticResource AppDataGridStyle}"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              HeadersVisibility="Column">     
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã NCC"
                                                Binding="{Binding SupplierId}"
                                                Width="60"/>
                                <DataGridTextColumn Header="Tên nhà cung cấp"
                                                Binding="{Binding SupplierName}"
                                                Width="*"/>
                                <DataGridTextColumn Header="Điện thoại"
                                                Binding="{Binding Phone}"
                                                Width="100"/>
                                <DataGridTextColumn Header="Email"
                                                Binding="{Binding Email}"
                                                Width="170"/>
                                <DataGridTextColumn Header="Trạng thái"
                                                Binding="{Binding StatusText}"
                                                Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</UserControl>
